<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>GIFT ME ร้านขายตุ๊กตา พวงกุญแจ กล่องสุ่มราคาพิเศษ</title>
    <link rel="icon" type="image/png" href="/img/logo32.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        function getAuthToken() {
            // 1. ลองดูใน URL ก่อน (กรณีเพิ่ง Redirect มาจาก Login)
            const urlParams = new URLSearchParams(window.location.search);
            const tokenFromUrl = urlParams.get('access_token');

            if (tokenFromUrl) {
                localStorage.setItem('my_token', tokenFromUrl);
                // ลบ token ออกจาก URL เพื่อความปลอดภัย/สวยงาม
                window.history.replaceState({}, document.title, window.location.pathname);
                return tokenFromUrl;
            }

            // 2. ถ้าใน URL ไม่มี ให้ไปดูใน LocalStorage
            return localStorage.getItem('my_token');
        }
        function logout() {
            localStorage.removeItem('my_token'); // ลบ Token
            localStorage.removeItem('user_fname'); // ลบชื่อ
            // จากนั้นค่อยพาไปหน้า Login หรือหน้าแรก
            window.location.href = '/auth/logout';
        }
        function handleLogout() {
            // 1. ลบ Token ออกจาก LocalStorage ทันที
            localStorage.removeItem('my_token');
            localStorage.removeItem('user_fname');

            // 2. ปล่อยให้มันวิ่งไปหา href="/auth/logout" เพื่อไปล้าง Session ที่ Server ต่อ
            return true;
        }
    </script>
    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #fff7fb;
            font-family: 'kanit';
        }

        /* HEADER */
        .header {
            background: #ffd6ec;
            padding: 18px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            font-family: 'kanit';
        }

        /* LOGO */
        .logo {
            font-size: 24px;
            font-weight: bold;
            color: #d63384;
        }

        /* MENU */
        .nav a {
            margin-left: 20px;
            text-decoration: none;
            color: #c2185b;
            font-weight: 500;

        }

        .nav a:hover {
            color: #ff4fa3;
        }

        /* CONTENT */
        .container {
            padding: 40px;
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>

    <nav class="sticky top-0 z-50 bg-pink-200 backdrop-blur-md border-b border-pink-100 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">

            <div class="flex items-center gap-2 group cursor-pointer">
                <img src="/img/logo2.jpg" alt="Gift Me โลโก้ร้านขายตุ๊กตาและของขวัญ">
            </div>



            <div class="hidden md:flex items-center gap-8">
                <div class="flex items-center gap-4">
                    <% if (!user) { %>
                        <a href="/auth/login"
                            class="transition-all duration-300 hover:scale-110 bg-pink-400 hover:bg-pink-500 text-white px-6 py-2 rounded-full font-bold shadow-md">
                            เข้าสู่ระบบ
                        </a>
                        <% } else { %>
                            <div
                                class="flex items-center gap-3 bg-pink-50 px-4 py-1.5 rounded-full border border-pink-100">
                                <span class="text-pink-600 font-bold text-sm">
                                    🧸 สวัสดี, <span id="display-fname">
                                        <%= user.user_fname %>
                                    </span>
                                </span>
                            </div>
                            <div class="w-px h-4 bg-pink-200"></div>
                            <a href="/auth/logout" onclick="return handleLogout()"
                                class="text-gray-400 hover:text-red-500 text-xs font-semibold transition-colors">
                                ออกจากระบบ
                            </a>
                            <% } %>
                </div>

                <a href="/"
                    class="transition-all duration-300 hover:scale-110 text-gray-600 hover:text-pink-500 font-medium relative group">หน้าแรก</a>
                <a href="/show"
                    class="transition-all duration-300 hover:scale-110 text-gray-600 hover:text-pink-500 font-medium relative group">สินค้า</a>
                <a href="/promotion"
                    class="transition-all duration-300 hover:scale-110 text-gray-600 hover:text-pink-500 font-medium relative group">โปรโมชั่น</a>
                <a href="/contact"
                    class="transition-all duration-300 hover:scale-110 text-gray-600 hover:text-pink-500 font-medium relative group">ติดต่อเรา</a>
            </div>

            <div class="md:hidden text-pink-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
            </div>
        </div>
    </nav>
    <script>
        // ดึงชื่อที่เทอเก็บไว้ตอน Login สำเร็จออกมา
        const userName = localStorage.getItem('user_fname');

        if (userName) {
            // ถ้าเจอชื่อ ให้เปลี่ยนคำว่า "ผู้เยี่ยมชม" เป็นชื่อลูกค้า
            document.getElementById('display-fname').innerText = userName;
        }


    </script>
    <div class="max-w-7xl mx-auto p-10">