<%- include('partials/header') %>

    <div class="relative w-fit mx-auto">
    
    <img src="/img/ct1.webp" alt="โปรโมชั่น Labubu ลดราคา15%" class="rounded-2xl">

</div>

    <h2 class="text-3xl font-bold mb-6 mt-20">Dolls</h2>

    <div class="grid-cols-2 md:grid-cols-3 lg:grid-cols-4">

        <% dolls.forEach(d=> { %>

            <div class="bg-white shadow-lg rounded-lg p-4">

                <img src="/img/<%= d.doll_picture %>" alt="สินค้าตุ๊กตา" class="w-full h-56 object-cover rounded">

                <h3 class="text-xl font-semibold mt-3">
                    <%= d.doll_name %>
                </h3>

                <p class="text-gray-600">
                    Price : <%= d.doll_price %>
                </p>
                <button onclick="openPayment('<%= d.doll_name %>', <%= d.doll_price %>)"
                class="mt-4 w-full bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 rounded-xl transition-all transform hover:scale-105">
                <i class="fa-solid fa-cart-shopping mr-2"></i>สั่งซื้อ
            </button>

            </div>
            

            <% }) %>

    </div>

    <h2 class="text-3xl font-bold mt-12 mb-6">Keychains</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 px-4">

        <% keys.forEach(k=> { %>

            <div class="bg-white shadow-lg rounded-lg p-4">

                <img src="/img/<%= k.key_picture %>" alt="สินค้าพวงกุญแจ" class="w-full h-56 object-cover rounded">

                <h3 class="text-xl font-semibold mt-3">
                    <%= k.key_name %>
                </h3>

                <p class="text-gray-600">
                    Price : <%= k.key_price %>
                </p>
                <button onclick="openPayment('<%= k.key_name %>', <%= k.key_price %>)"
                class="mt-4 w-full bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 rounded-xl transition-all transform hover:scale-105">
                <i class="fa-solid fa-cart-shopping mr-2"></i>สั่งซื้อ
            </button>

            </div>

            <% }) %>

    </div>

    <div class="flex flex-col md:flex-row items-center justify-center gap-6 mt-10 px-4">

    <!-- 🖼️ รูป -->
    <img src="/img/bear4.jpg" alt="ติดต่อฉัน ตุ๊กตาหมี" class="w-64 rounded-2xl">

    <!-- 📩 ฟอร์ม -->
    <div class="bg-pink-100 p-8 rounded-2xl shadow-lg w-full max-w-sm">
        <h2 class="text-2xl text-pink-600 font-bold mb-6 text-center">สอบถามสินค้า</h2>

        <form action="/request" method="POST" class="space-y-4">

            <input type="text" name="req_name" placeholder="ชื่อ"
                class="w-full border rounded-xl p-3">

            <input type="text" name="req_tel" placeholder="เบอร์โทร"
                class="w-full border rounded-xl p-3">

            <textarea name="req_mes" placeholder="ข้อความ (200 ตัวอักษร)"
                class="w-full border rounded-xl p-3"></textarea>

            <button class="w-full bg-pink-500 text-white py-3 rounded-xl">
                ส่งคำร้อง
            </button>

        </form>
    </div>

</div>
    <%- include('partials/footer') %>

    <div id="paymentModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
    <div class="bg-white p-8 rounded-3xl max-w-sm w-full text-center shadow-2xl">
        <h2 class="text-2xl font-bold mb-2">ชำระเงิน</h2>
        <p id="pay-item-name" class="text-gray-600 mb-4"></p>
        
        <div class="bg-gray-100 p-4 rounded-2xl mb-4 inline-block">
            <img id="qr-image" src="" alt="PromptPay QR" class="mx-auto w-48 h-48">
        </div>

        <p class="text-xl font-bold text-pink-600 mb-6">
            ยอดชำระ: <span id="pay-amount"></span> บาท
        </p>

        <button onclick="closePayment()" class="w-full bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-2 rounded-xl">
            ยกเลิก
        </button>
    </div>
</div>

<script>
    function openPayment(name, price) {
        const modal = document.getElementById('paymentModal');
        const payName = document.getElementById('pay-item-name');
        const payAmount = document.getElementById('pay-amount');
        const qrImg = document.getElementById('qr-image');

        // ใส่ข้อมูลสินค้า
        payName.innerText = name;
        payAmount.innerText = price.toLocaleString();

        // สร้าง URL สำหรับ PromptPay QR Code (จำลอง)
        // หมายเหตุ: 0834765037 คือเบอร์ที่เทอใส่ใน Footer (สมมติว่าเป็นเบอร์พร้อมเพย์นะจ๊ะ)
        const promptpayId = "0834765037"; 
        qrImg.src = `https://promptpay.io/${promptpayId}/${price}.png`;

        // แสดง Modal
        modal.classList.remove('hidden');
    }

    function closePayment() {
        document.getElementById('paymentModal').classList.add('hidden');
    }
</script>