<%- include('partials/header') %> 

<div class="min-h-screen flex items-center justify-center bg-pink-50 py-12 px-4">
    <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-lg border border-pink-100">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-gray-800">สมัครสมาชิก 🧸</h2>
            <p class="text-pink-400">เข้าร่วมครอบครัว Doll Gift Shop กับเรานะจ๊ะ</p>
        </div>

        <form action="/auth/signup" method="POST" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-600">ชื่อจริง</label>
                    <input type="text" name="user_fname" required class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600">นามสกุล</label>
                    <input type="text" name="user_lname" required class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-600">Username (ID)</label>
                <input type="text" name="user_id" required class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-600">Email</label>
                <input type="email" name="user_email" required class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-600">รหัสผ่าน</label>
                <input type="password" name="user_pass" required class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
            </div>

            <button type="submit" class="w-full bg-pink-500 hover:bg-pink-600 text-white font-bold py-3 rounded-xl transition duration-300 shadow-md">
                ยืนยันการสมัคร ✨
            </button>
        </form>
        
        <p class="mt-6 text-center text-sm text-gray-500">
            มีบัญชีอยู่แล้ว? <a href="/auth/login" class="text-pink-500 font-semibold hover:underline">เข้าสู่ระบบ</a>
        </p>
    </div>
</div>
<%- include('partials/footer') %>