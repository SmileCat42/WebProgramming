<%- include('partials/header') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="min-h-screen flex items-center justify-center bg-pink-50 py-12 px-4">
    <div class="max-w-md w-full bg-white p-8 rounded-2xl shadow-lg border border-pink-100">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-gray-800">สมัครสมาชิก</h2>
            <p class="text-pink-400">เข้าร่วมครอบครัว Doll Gift Shop</p>
        </div>

        <form onsubmit="handleSignup(event)" class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-600">ชื่อจริง</label>
                    <input type="text" id="user_fname" name="user_fname" required
                        class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-600">นามสกุล</label>
                    <input type="text" id="user_lname" name="user_lname" required
                        class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-600">Username (ID)</label>
                <input type="text" id="user_id" name="user_id" required
                    class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-600">Email</label>
                <input type="email" id="user_email" name="user_email" required
                    class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-600">รหัสผ่าน</label>
                <input type="password" id="user_pass" name="user_pass" required
                    class="w-full px-4 py-2 mt-1 border rounded-lg focus:ring-2 focus:ring-pink-300 outline-none">
            </div>

            <button type="submit" 
                class="w-full bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 px-4 rounded-lg transition duration-200">
                ยืนยันการสมัคร
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-gray-500">
            มีบัญชีอยู่แล้ว? <a href="/login" class="text-pink-500 font-semibold hover:underline">เข้าสู่ระบบ</a>
        </p>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    async function handleSignup(event) {
        event.preventDefault();

        const user_id = document.getElementById('user_id').value;
        const user_pass = document.getElementById('user_pass').value;
        const user_fname = document.getElementById('user_fname').value;
        const user_lname = document.getElementById('user_lname').value;
        const user_email = document.getElementById('user_email').value;

        try {
            // เช็ค Path ให้ตรงกับ Controller หลังบ้านนะจ๊ะ (เช่น /auth/signup หรือ /user/signup)
            const response = await fetch('/auth/signup', { 
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    user_id,
                    user_pass,
                    user_fname,
                    user_lname,
                    user_email
                })
            });

            const data = await response.json();

            if (response.ok) {
                Swal.fire({
                    title: 'สมัครสมาชิกสำเร็จ!',
                    text: `ยินดีต้อนรับคุณ ${user_fname} เข้าสู่ร้านของเรา`,
                    icon: 'success',
                    confirmButtonColor: '#ec4899',
                    confirmButtonText: 'ไปหน้า Login กันเลย!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '/auth/login'; 
                    }
                });
            } else {
                Swal.fire({
                    title: 'สมัครไม่สำเร็จ',
                    text: data.message || 'ID นี้อาจจะถูกใช้ไปแล้ว',
                    icon: 'error',
                    confirmButtonColor: '#666'
                });
            }
        } catch (error) {
            console.error('Error:', error);
            Swal.fire('ระบบขัดข้อง', 'ลองใหม่อีกครั้ง', 'warning');
        }
    }
</script>