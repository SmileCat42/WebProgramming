<%- include('partials/header') %>
<script>
    // ดักหน้าประตู: ถ้าไม่มี Token ให้ดีดออกไปหน้า Login ทันที
    const checkToken = localStorage.getItem('my_token');
    if (!checkToken) {
        alert('พื้นที่เฉพาะ ADMIN เท่านั้น กรุณาเข้าสู่ระบบค่ะ');
        window.location.href = '/auth/login';
    }
</script>

<div class="flex justify-between items-center mb-8">
    <h2 class="font-bold text-3xl text-purple-700">ระบบจัดการข้อมูลสินค้า (CMS)</h2>
    <button onclick="prepareCreate()" class="bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg font-bold shadow-lg transition-all">
        + เพิ่มสินค้าใหม่
    </button>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
    <div class="bg-white p-6 rounded-2xl shadow-md border border-pink-100">
        <h3 class="text-xl font-bold text-pink-600 mb-4 flex items-center">🧸 รายการตุ๊กตา (Dolls)</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b-2 border-pink-50 text-pink-400">
                        <th class="py-3 px-2">รูป</th>
                        <th class="py-3 px-2">ชื่อสินค้า</th>
                        <th class="py-3 px-2 text-right">ราคา</th>
                        <th class="py-3 px-2 text-center">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% dolls.forEach(d => { %>
                    <tr class="border-b border-pink-50 hover:bg-pink-50 transition-colors">
                        <td class="py-3 px-2"><img src="/img/<%= d.doll_picture %>" class="w-12 h-12 rounded-lg object-cover shadow-sm"></td>
                        <td class="py-3 px-2 font-medium"><%= d.doll_name %></td>
                        <td class="py-3 px-2 text-right text-purple-600 font-bold"><%= d.doll_price %>.-</td>
                        <td class="py-3 px-2 text-center">
                            <button onclick="editData('<%= d.doll_id %>', 'doll')" class="text-blue-500 hover:text-blue-700 mx-1"><i class="fas fa-edit"></i></button>
                            <button onclick="removeData('<%= d.doll_id %>', 'doll')" class="text-red-500 hover:text-red-700 mx-1"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-md border border-purple-100">
        <h3 class="text-xl font-bold text-purple-600 mb-4 flex items-center">🔑 รายการพวงกุญแจ (Keychains)</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b-2 border-purple-50 text-purple-400">
                        <th class="py-3 px-2">รูป</th>
                        <th class="py-3 px-2">ชื่อสินค้า</th>
                        <th class="py-3 px-2 text-right">ราคา</th>
                        <th class="py-3 px-2 text-center">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% keys.forEach(k => { %>
                    <tr class="border-b border-purple-50 hover:bg-purple-50 transition-colors">
                        <td class="py-3 px-2"><img src="/img/<%= k.key_picture %>" class="w-12 h-12 rounded-lg object-cover shadow-sm"></td>
                        <td class="py-3 px-2 font-medium"><%= k.key_name %></td>
                        <td class="py-3 px-2 text-right text-purple-600 font-bold"><%= k.key_price %>.-</td>
                        <td class="py-3 px-2 text-center">
                            <button onclick="editData('<%= k.key_id %>', 'key')" class="text-blue-500 hover:text-blue-700 mx-1"><i class="fas fa-edit"></i></button>
                            <button onclick="removeData('<%= k.key_id %>', 'key')" class="text-red-500 hover:text-red-700 mx-1"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="editor-section" class="hidden bg-purple-100 w-full p-8 rounded-3xl shadow-inner mb-20 border-2 border-purple-200">
    <div class="flex justify-between items-center mb-6">
        <h2 id="editor-title" class="text-2xl font-bold text-purple-800 underline">📝 แก้ไขข้อมูล</h2>
        <button onclick="closeEditor()" class="text-gray-500 hover:text-gray-700 text-2xl">&times;</button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
            <input type="hidden" id="item_id">
            <div>
                <label class="block text-sm font-bold text-purple-700">ชื่อสินค้า :</label>
                <input id="doll_name" type="text" class="w-full border-2 border-white focus:border-purple-400 outline-none p-3 rounded-xl bg-white/70 shadow-sm transition-all">
            </div>
            <div>
                <label class="block text-sm font-bold text-purple-700">ราคา :</label>
                <input id="doll_price" type="number" class="w-full border-2 border-white focus:border-purple-400 outline-none p-3 rounded-xl bg-white/70 shadow-sm transition-all">
            </div>
            <div>
                <label class="block text-sm font-bold text-purple-700">ชื่อไฟล์รูปภาพ (เช่น doll1.png) :</label>
                <input id="doll_picture" type="text" class="w-full border-2 border-white focus:border-purple-400 outline-none p-3 rounded-xl bg-white/70 shadow-sm transition-all">
            </div>
        </div>
        <div class="flex flex-col items-center justify-center border-2 border-dashed border-purple-300 rounded-3xl p-4 bg-white/50">
            <p class="text-sm text-purple-400 mb-2">ตัวอย่างรูปภาพ</p>
            <img id="img-preview" src="/img/no-image.png" class="w-40 h-40 object-cover rounded-2xl shadow-lg border-4 border-white">
        </div>
    </div>

    <div class="mt-8 flex justify-end gap-4">
        <button id="btn-save" onclick="saveData()" class="bg-purple-600 hover:bg-purple-700 text-white px-8 py-3 rounded-xl font-bold shadow-lg transition-all">บันทึกข้อมูล</button>
        <button onclick="closeEditor()" class="bg-gray-400 hover:bg-gray-500 text-white px-8 py-3 rounded-xl font-bold shadow-lg transition-all">ยกเลิก</button>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    let currentType = '';
    let mode = 'create'; // 'create' or 'edit'
    const token = getAuthToken();

    // ฟังก์ชันเปิดฟอร์มสำหรับ เพิ่มใหม่
    function prepareCreate() {
        mode = 'create';
        Swal.fire({
            title: 'เลือกประเภทสินค้า',
            input: 'select',
            inputOptions: { 'doll': 'ตุ๊กตา (Doll)', 'key': 'พวงกุญแจ (Key)' },
            confirmButtonText: 'ตกลง',
            confirmButtonColor: '#9333ea'
        }).then((result) => {
            if (result.value) {
                currentType = result.value;
                resetForm();
                document.getElementById('editor-title').innerText = "➕ เพิ่ม" + (currentType === 'doll' ? 'ตุ๊กตา' : 'พวงกุญแจ');
                document.getElementById('editor-section').classList.remove('hidden');
                document.getElementById('editor-section').scrollIntoView({ behavior: 'smooth' });
            }
        });
    }

    // ฟังก์ชันดึงข้อมูลมา แก้ไข
    async function editData(id, type) {
        mode = 'edit';
        currentType = type;
        const response = await fetch(`/api/${type}/${id}`);
        const data = await response.json();
        
        const prefix = type === 'doll' ? 'doll_' : 'key_';
        document.getElementById('item_id').value = data[prefix + 'id'];
        document.getElementById('doll_name').value = data[prefix + 'name'];
        document.getElementById('doll_price').value = data[prefix + 'price'];
        document.getElementById('doll_picture').value = data[prefix + 'picture'];
        document.getElementById('img-preview').src = "/img/" + data[prefix + 'picture'];

        document.getElementById('editor-title').innerText = "📝 แก้ไข" + (type === 'doll' ? 'ตุ๊กตา' : 'พวงกุญแจ');
        document.getElementById('editor-section').classList.remove('hidden');
        document.getElementById('editor-section').scrollIntoView({ behavior: 'smooth' });
    }

    function resetForm() {
        document.getElementById('item_id').value = '';
        document.getElementById('doll_name').value = '';
        document.getElementById('doll_price').value = '';
        document.getElementById('doll_picture').value = '';
        document.getElementById('img-preview').src = '/img/no-image.png';
    }

    function closeEditor() {
        document.getElementById('editor-section').classList.add('hidden');
    }

    // ฟังก์ชัน Save (รวมทั้ง Create และ Update)
    async function saveData() {
        const id = document.getElementById('item_id').value;
        const url = mode === 'create' ? `/api/${currentType}` : `/api/${currentType}/${id}`;
        const method = mode === 'create' ? 'POST' : 'PUT';

        const payload = currentType === 'doll' ? {
            doll_name: document.getElementById('doll_name').value,
            doll_price: document.getElementById('doll_price').value,
            doll_picture: document.getElementById('doll_picture').value
        } : {
            key_name: document.getElementById('doll_name').value,
            key_price: document.getElementById('doll_price').value,
            key_picture: document.getElementById('doll_picture').value
        };

        const res = await fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
            body: JSON.stringify(payload)
        });
        handleResponse(res, mode === 'create' ? 'เพิ่มสำเร็จ!' : 'แก้ไขสำเร็จ!');
    }

    async function removeData(id, type) {
        currentType = type;
        const confirm = await Swal.fire({
            title: 'ลบข้อมูลนี้?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444'
        });
        if (confirm.isConfirmed) {
            const res = await fetch(`/api/${type}/${id}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            handleResponse(res, 'ลบเรียบร้อย!');
        }
    }

    async function handleResponse(response, msg) {
        if (response.ok) {
            Swal.fire('สำเร็จ', msg, 'success').then(() => location.reload());
        } else {
            const err = await response.json();
            Swal.fire('ผิดพลาด', err.message || 'ไม่มีสิทธิ์เข้าถึง', 'error');
        }
    }
</script>